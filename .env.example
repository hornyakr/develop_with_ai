# Public values must be safe for the browser. Never place secrets in NEXT_PUBLIC_*.
NEXT_PUBLIC_APP_NAME=Atlas Workspace

# Server-only values. Replace through a secret manager; do not commit real values.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/atlas?schema=public
AUTH_SECRET=replace-with-secret-manager-value
AI_PROVIDER=openai
AI_MODEL_FAST=provider-model-id
AI_MODEL_REASONING=provider-model-id
